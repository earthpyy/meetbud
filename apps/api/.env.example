PORT=3000
APP_ORIGIN=http://localhost:5173

# Postgres (provisioned by `pnpm infra:up`, host port 5433). Used by Prisma (schema + seed).
DATABASE_URL=postgresql://meetbud:meetbud@localhost:5433/meetbud

# Optional overrides for the admin seed (prisma/seed.ts).
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_NAME=Admin

# ── Auth / JWT (TTLs in seconds) ──
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
OTP_TTL=600

# ── Redis (provisioned by `pnpm infra:up`, host port 6380) ──
REDIS_URL=redis://localhost:6380

# ── SMTP (dev → Mailpit on host port 1026, UI http://localhost:8026; leave SMTP_HOST unset to log emails to the console) ──
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_FROM=meetbud <no-reply@meetbud.local>
# SMTP_USER=
# SMTP_PASS=
