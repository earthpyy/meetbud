// meetbud schema: users/auth (seeded) plus the meetings & notes domain.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  member
}

enum UserStatus {
  active
  invited
}

enum AutoRecord {
  all
  organized
  off
}

model User {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String
  title       String?
  timezone    String?
  role        Role            @default(member)
  status      UserStatus      @default(active)
  lastLoginAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  preferences UserPreference?

  organizedMeetings Meeting[]     @relation("MeetingOrganizer")
  participations    Participant[]

  @@map("users")
}

model UserPreference {
  id                  String     @id @default(cuid())
  userId              String     @unique
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoRecord          AutoRecord @default(organized)
  joinEarly           Boolean    @default(true)
  notifyOnSummary     Boolean    @default(true)
  customPromptEnabled Boolean    @default(false)
  customPrompt        String?
  weeklyDigest        Boolean    @default(true)
  slackSummaries      Boolean    @default(false)
  updatedAt           DateTime   @updatedAt

  @@map("user_preferences")
}

enum MeetingPlatform {
  meet
  zoom
  teams
}

enum MeetingStatus {
  upcoming
  ongoing
  transcribing
  summarizing
  done
}

enum RecordingStatus {
  scheduled
  joining
  in_call
  recording
  done
  failed
}

model Meeting {
  id               String          @id @default(cuid())
  title            String
  description      String?
  platform         MeetingPlatform
  status           MeetingStatus   @default(upcoming)
  startAt          DateTime
  endAt            DateTime
  joinUrl          String?
  recordingEnabled Boolean         @default(true)
  organizerId      String
  organizer        User            @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  calendarEventId  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  participants Participant[]
  recording    Recording?
  transcript   TranscriptSegment[]
  summary      Summary?

  @@index([organizerId])
  @@map("meetings")
}

model Participant {
  id                  String   @id @default(cuid())
  meetingId           String
  meeting             Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?    @relation(fields: [userId], references: [id])
  name                String
  email               String?
  title               String?
  isOrganizer         Boolean  @default(false)
  isExternal          Boolean  @default(false)
  recallParticipantId String?
  createdAt           DateTime @default(now())

  segments TranscriptSegment[]

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@map("participants")
}

model Recording {
  id                String          @id @default(cuid())
  meetingId         String          @unique
  meeting           Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  recallBotId       String?
  recallRecordingId String?
  status            RecordingStatus @default(scheduled)
  audioUrl          String?
  videoUrl          String?
  mediaExpiresAt    DateTime?
  durationSec       Int?
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("recordings")
}

model TranscriptSegment {
  id            String       @id @default(cuid())
  meetingId     String
  meeting       Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  participantId String?
  participant   Participant? @relation(fields: [participantId], references: [id])
  startSec      Float
  endSec        Float?
  text          String
  order         Int
  createdAt     DateTime     @default(now())

  @@index([meetingId, startSec])
  @@map("transcript_segments")
}

model Summary {
  id          String    @id @default(cuid())
  meetingId   String    @unique
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  tldr         String
  content      Json
  inputTokens  Int?
  outputTokens Int?
  model        String?
  generatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("summaries")
}

model WorkspaceSettings {
  id                     String   @id @default("default")
  aiApiKey               String?
  aiBaseUrl              String   @default("https://api.anthropic.com")
  aiModel                String   @default("claude-opus-4-8")
  aiTemperature          Float    @default(0.3)
  aiSystemPrompt         String   @default("You are a meeting-notes assistant. Summarize the transcript into a concise TL;DR, key points, decisions, and action items with owners. Be specific and never invent details.")
  recallApiKey           String?
  recallBotName          String   @default("meetbud Notetaker")
  recallRegion           String   @default("us-east-1")
  recordingRetentionDays Int      @default(90)
  recallAutoLeave        Boolean  @default(true)
  updatedAt              DateTime @updatedAt

  @@map("workspace_settings")
}
